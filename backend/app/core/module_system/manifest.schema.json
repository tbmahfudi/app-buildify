{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AppBuildify Module Manifest",
  "description": "Schema for module manifest.json files",
  "type": "object",
  "required": [
    "name",
    "display_name",
    "version",
    "module_type",
    "category",
    "api_prefix"
  ],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]{1,98}[a-z0-9]$",
      "description": "Unique module identifier (lowercase, underscores/hyphens allowed)"
    },
    "display_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*))*))?(?:\\+([0-9a-zA-Z-]+(?:\\.[0-9a-zA-Z-]+)*))?$",
      "description": "Semantic version (semver 2.0 strict)"
    },
    "module_type": {
      "type": "string",
      "enum": [
        "code",
        "nocode"
      ],
      "description": "Module implementation type: code (FastAPI service) or nocode (configuration-driven)"
    },
    "category": {
      "type": "string",
      "minLength": 1,
      "maxLength": 50,
      "description": "Module category for UI grouping"
    },
    "api_prefix": {
      "type": "string",
      "pattern": "^/[a-zA-Z0-9/_-]+$",
      "description": "URL prefix for this module's API routes (e.g. /api/v1/mymodule)"
    },
    "permissions": {
      "type": "array",
      "default": [],
      "uniqueItems": true,
      "items": {
        "type": "object",
        "required": [
          "name",
          "description"
        ],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_.:-]*$",
            "description": "Permission code (e.g. mymodule.read)"
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          },
          "resource": {
            "type": "string"
          },
          "action": {
            "type": "string"
          }
        }
      }
    },
    "menu_items": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "required": [
          "label",
          "route"
        ],
        "additionalProperties": false,
        "properties": {
          "label": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          },
          "route": {
            "type": "string",
            "minLength": 1
          },
          "icon": {
            "type": "string"
          },
          "permission": {
            "type": "string"
          },
          "order": {
            "type": "integer",
            "minimum": 0
          },
          "parent": {
            "type": "string"
          }
        }
      }
    },
    "routes": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "required": [
          "path",
          "name"
        ],
        "additionalProperties": false,
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "component": {
            "type": "string"
          },
          "permission": {
            "type": "string"
          },
          "menu": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "label": {
                "type": "string"
              },
              "icon": {
                "type": "string"
              },
              "order": {
                "type": "integer"
              },
              "parent": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "event_subscriptions": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "required": [
          "event",
          "handler"
        ],
        "additionalProperties": false,
        "properties": {
          "event": {
            "type": "string",
            "minLength": 1,
            "description": "Platform event name to subscribe to (e.g. tenant.created)"
          },
          "handler": {
            "type": "string",
            "minLength": 1,
            "description": "Python dotted path to the handler callable"
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "dependencies": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "required": [
          "name"
        ],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_-]{1,98}[a-z0-9]$",
            "description": "Module name of the dependency"
          },
          "version": {
            "type": "string",
            "description": "Minimum semver version required (optional)"
          },
          "optional": {
            "type": "boolean",
            "default": false,
            "description": "If true, module works without this dep but gains features with it"
          }
        }
      }
    },
    "description": {
      "type": "string",
      "maxLength": 2000
    },
    "author": {
      "type": "string",
      "maxLength": 255
    },
    "license": {
      "type": "string",
      "maxLength": 100
    },
    "homepage": {
      "type": "string",
      "format": "uri"
    },
    "repository": {
      "type": "string",
      "format": "uri"
    },
    "support_email": {
      "type": "string",
      "format": "email"
    },
    "subscription_tier": {
      "type": "string",
      "enum": [
        "free",
        "basic",
        "premium",
        "enterprise"
      ]
    },
    "is_core": {
      "type": "boolean",
      "default": false
    },
    "backend_service_url": {
      "type": "string",
      "format": "uri"
    },
    "configuration": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "settings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "key",
              "type"
            ],
            "additionalProperties": false,
            "properties": {
              "key": {
                "type": "string"
              },
              "type": {
                "type": "string",
                "enum": [
                  "string",
                  "integer",
                  "boolean",
                  "json"
                ]
              },
              "default": {},
              "description": {
                "type": "string"
              },
              "required": {
                "type": "boolean"
              }
            }
          }
        }
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "parent_module": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Parent module name for sub-modules"
    },
    "deployment": {
      "type": "object",
      "additionalProperties": false,
      "description": "Deployment topology configuration",
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "embedded",
            "standalone",
            "inherit",
            "any"
          ]
        },
        "port": {
          "type": "integer",
          "minimum": 9002,
          "maximum": 9099
        }
      }
    },
    "public_portal": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "entry_point": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "routing": {
          "type": "string",
          "enum": [
            "hash",
            "path"
          ],
          "default": "hash",
          "description": "Client-side routing mode for the portal SPA. hash (default, SEO-weak) or path (opt-in, needs SPA fallback)."
        },
        "tenant_resolution": {
          "type": "string",
          "enum": [
            "slug_in_path",
            "none"
          ],
          "default": "slug_in_path",
          "description": "How the portal resolves the tenant for clinic-scoped pages."
        },
        "routes": {
          "type": "array",
          "default": [],
          "description": "Client-side portal routes, distinct from staff/admin routes[].",
          "items": {
            "type": "object",
            "required": [
              "path"
            ],
            "additionalProperties": false,
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1,
                "description": "Client-side portal route (hash or path)."
              },
              "audience": {
                "type": "string",
                "default": "public",
                "description": "public = anonymous; any other value (e.g. patient) requires an end-user token client-side. Trust is enforced server-side at the API, not here."
              },
              "title": {
                "type": "string"
              }
            }
          }
        }
      },
      "description": "Public/patient-facing static portal app served at /portal/{module}/ (ADR module-public-pages)."
    },
    "entry_point": {
      "type": "string",
      "description": "Module admin-SPA JS entry (e.g. module.js)."
    },
    "navigation": {
      "type": "object",
      "description": "Primary-menu navigation hints for the admin SPA.",
      "additionalProperties": true
    }
  }
}
