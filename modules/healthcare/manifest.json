{
  "name": "healthcare",
  "display_name": "Healthcare",
  "version": "1.0.0",
  "description": "Two-sided healthcare platform: clinic staff portal + patient portal. Includes scheduling, billing, pharmacy, and laboratory sub-modules.",
  "routes": [
    {
