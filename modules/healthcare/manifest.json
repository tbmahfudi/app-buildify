      "menu": {
        "label": "Prescriptions",
        "icon": "ph-duotone ph-pill",
        "order": 25,
        "parent": "healthcare"
      }
    },
    {
      "path": "#/healthcare/lab-orders",
      "name": "Lab Orders",
      "component": "frontend/clinic/lab-orders.js",
      "permission": "healthcare:lab:read",
      "menu": {
        "label": "Lab Orders",
        "icon": "ph-duotone ph-flask",
        "order": 26,
        "parent": "healthcare"
      }
    }
  ],
  "dependencies": [],
