{
  "name": "healthcare",
  "display_name": "Healthcare",
  "version": "1.1.0",
  "description": "Two-sided healthcare platform: clinic staff portal + patient portal. Includes scheduling, billing, pharmacy, and laboratory sub-modules.",
  "entry_point": "module.js",
  "routes": [
    {
      "path": "#/healthcare/dashboard",
      "name": "Healthcare Dashboard",
      "component": "pages/dashboard.js",
      "permission": "healthcare:dashboard:read",
      "menu": {
        "label": "Dashboard",
        "icon": "ph-duotone ph-squares-four",
        "order": 21,
        "parent": "healthcare"
      }
    },
    {
      "path": "#/healthcare/appointments",
      "name": "Appointments",
      "component": "pages/appointments.js",
      "permission": "healthcare:appointments:read",
      "menu": {
        "label": "Appointments",
        "icon": "ph-duotone ph-calendar-check",
        "order": 22,
        "parent": "healthcare"
      }
    },
    {
      "path": "#/healthcare/schedules",
      "name": "Schedules",
      "component": "pages/schedules.js",
      "permission": "healthcare:schedules:read",
      "menu": {
        "label": "Schedules",
        "icon": "ph-duotone ph-calendar",
        "order": 23,
        "parent": "healthcare"
      }
    },
    {
      "path": "#/healthcare/invoices",
      "name": "Invoices",
      "component": "pages/invoices.js",
      "permission": "healthcare:billing:read",
      "menu": {
        "label": "Invoices",
        "icon": "ph-duotone ph-receipt",
        "order": 24,
        "parent": "healthcare"
      }
    },
    {
      "path": "#/healthcare/prescriptions",
      "name": "Prescriptions",
      "component": "pages/prescriptions.js",
      "permission": "healthcare:pharmacy:read",
      "menu": {
        "label": "Prescriptions",
        "icon": "ph-duotone ph-pill",
        "order": 25,
        "parent": "healthcare"
      }
    },
    {
      "path": "#/healthcare/lab-orders",
      "name": "Lab Orders",
      "component": "pages/lab-orders.js",
      "permission": "healthcare:lab:read",
      "menu": {
        "label": "Lab Orders",
        "icon": "ph-duotone ph-flask",
        "order": 26,
        "parent": "healthcare"
      }
    }
  ],
  "navigation": {
    "primary_menu": true,
    "menu_items": [
      {
        "code": "healthcare",
        "label": "Healthcare",
        "icon": "ph-duotone ph-first-aid-kit",
        "icon_color": "text-rose-600",
        "order": 20,
        "is_parent": true,
        "permission": null
      }
    ]
  },
  "dependencies": [],
  "module_type": "code",
  "category": "vertical",
  "api_prefix": "/api/v1/healthcare",
  "public_portal": {
    "enabled": true,
    "entry_point": "frontend/public/index.html",
    "title": "Find a Clinic",
    "routing": "hash",
    "tenant_resolution": "slug_in_path",
    "routes": [
      {
        "path": "#search",
        "audience": "public",
        "title": "Find a clinic"
      },
