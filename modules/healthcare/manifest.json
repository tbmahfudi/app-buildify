      "menu": {
        "label": "Dashboard",
        "icon": "ph-duotone ph-squares-four",
        "order": 21,
        "parent": "healthcare"
      }
    },
    {
      "path": "#/healthcare/appointments",
      "name": "Appointments",
      "component": "frontend/clinic/appointment-queue.js",
      "permission": "healthcare:appointments:read",
      "menu": {
        "label": "Appointments",
        "icon": "ph-duotone ph-calendar-check",
        "order": 22,
        "parent": "healthcare"
      }
    },
    {
      "path": "#/healthcare/schedules",
      "name": "Schedules",
      "component": "frontend/clinic/schedule-editor.js",
      "permission": "healthcare:schedules:read",
      "menu": {
        "label": "Schedules",
        "icon": "ph-duotone ph-calendar",
        "order": 23,
        "parent": "healthcare"
      }
    },
    {
      "path": "#/healthcare/invoices",
      "name": "Invoices",
      "component": "frontend/clinic/invoices.js",
