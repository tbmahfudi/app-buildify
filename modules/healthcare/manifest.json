        "icon": "ph-duotone ph-receipt",
        "order": 24,
        "parent": "healthcare"
      }
    },
    {
      "path": "#/healthcare/prescriptions",
      "name": "Prescriptions",
      "component": "frontend/clinic/prescriptions.js",
